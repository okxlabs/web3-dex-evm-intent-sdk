# ETH Mainnet RPC URL (Alchemy / Infura / etc.)
RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_API_KEY

# Trader private key (the EOA that signs and owns orders)
PK=0x...

# Solver private key (authorized solver that calls settle())
SOLVER_PK=0x...

# Optional: path to deployments JSON (defaults to ../../deployments/eth_stg.json)
# DEPLOYMENTS_PATH=/path/to/deployments/eth_stg.json
