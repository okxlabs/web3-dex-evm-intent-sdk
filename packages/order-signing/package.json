{
  "name": "@okx-intent-swap/sdk-order-signing",
  "version": "1.0.0",
  "description": "Order signing utilities for IntentSwap SDK",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "typecheck": "tsc --noEmit",
    "test": "jest --config ../../jest.config.js --testPathPattern packages/order-signing --passWithNoTests"
  },
  "dependencies": {
    "@okx-intent-swap/sdk-common": "workspace:*",
    "@okx-intent-swap/sdk-config": "workspace:*"
  },
  "peerDependencies": {
    "ethers": "^5.7.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "ethers": "^5.7.0",
    "typescript": "^5.3.0"
  },
  "license": "LGPL-3.0-or-later"
}
