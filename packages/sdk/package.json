{
  "name": "@okx-intent-swap/sdk",
  "version": "1.0.0",
  "description": "IntentSwap SDK - Complete package for interacting with IntentSwap DEX protocol",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "typecheck": "tsc --noEmit",
    "test": "jest --passWithNoTests"
  },
  "dependencies": {
    "@okx-intent-swap/sdk-common": "workspace:*",
    "@okx-intent-swap/sdk-config": "workspace:*",
    "@okx-intent-swap/sdk-contracts": "workspace:*",
    "@okx-intent-swap/sdk-order-signing": "workspace:*",
    "@okx-intent-swap/sdk-trading": "workspace:*",
    "@okx-intent-swap/sdk-solver": "workspace:*",
    "@okx-intent-swap/sdk-ethers-v5-adapter": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.3.0"
  },
  "license": "LGPL-3.0-or-later",
  "repository": {
    "type": "git",
    "url": "git@github.com:okxlabs/web3-dex-evm-intent-sdk.git"
  },
  "keywords": [
    "okx",
    "intent-swap",
    "dex",
    "ethereum",
    "web3",
    "trading",
    "eip-712",
    "batch-settlement"
  ]
}
